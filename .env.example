# Mine Agent Configuration

# Platform Service
# Test environment (open access for testing):
PLATFORM_BASE_URL=http://101.47.73.95
# Production (requires wallet whitelisting - see PRODUCTION_SETUP.md):
# PLATFORM_BASE_URL=https://sd76fip34meovmfu5ftlg.apigateway-ap-southeast-1.volceapi.com

# Note: Miner identification is automatic via wallet address (no MINER_ID needed)

# AWP Wallet
AWP_WALLET_BIN=C:/nvm4w/nodejs/awp-wallet.cmd
# Get token from: awp-wallet unlock --duration 3600
AWP_WALLET_TOKEN=

# EIP-712 Signature Domain Parameters
# CRITICAL: These must match the platform's configuration
EIP712_DOMAIN_NAME=aDATA
EIP712_CHAIN_ID=8453
EIP712_VERIFYING_CONTRACT=0x0000000000000000000000000000000000000000

# Worker Configuration
# CRAWLER_ROOT=./crawlers
# OUTPUT_ROOT=./output
# STATE_ROOT=./state
# PYTHON_BIN=python
# MAX_PARALLEL=3
# DISCOVERY_MAX_PAGES=25
# DISCOVERY_MAX_DEPTH=1
